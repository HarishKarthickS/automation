NODE_ENV=development
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/automation?sslmode=disable
ADMIN_EMAILS=admin@example.com
BETTER_AUTH_SECRET=replace-with-long-random-string-min-32
BETTER_AUTH_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
MASTER_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
INTERNAL_CRON_TOKEN=replace-with-long-random-token
MAX_CODE_SIZE_BYTES=102400
MAX_OUTPUT_BYTES=262144
DEFAULT_TIMEOUT_SECONDS=30
MAX_TIMEOUT_SECONDS=120
EXECUTION_CONCURRENCY=3
PER_USER_CONCURRENT_RUNS=2
PER_USER_DAILY_RUN_LIMIT=200
MAX_RUN_ATTEMPTS=2
RUN_RETENTION_DAYS=30
OBS_ALERT_MIN_SUCCESS_RATE_24H=95
OBS_ALERT_MAX_EXHAUSTED_RETRIES_24H=5
OBS_ALERT_MAX_QUEUE_DEPTH=25
OBS_ALERT_MAX_SCHEDULER_LAG_MINUTES=5
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-gmail-app-password
AUTO_MIGRATE=false
REDIS_URL=redis://localhost:6379
REDIS_DUE_QUEUE=queue:run_due_automations
