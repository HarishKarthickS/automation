{
  "name": "@automation/api",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "predev": "corepack pnpm --filter @automation/shared build",
    "dev": "tsx watch src/server.ts",
    "prebuild": "corepack pnpm --filter @automation/shared build",
    "build": "tsc -p tsconfig.json",
    "prestart": "corepack pnpm --filter @automation/shared build",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "corepack pnpm --filter @automation/shared build",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@automation/shared": "workspace:*",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "better-auth": "1.1.18",
    "cron-parser": "^4.9.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.41.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.4",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
